<script type="text/javascript">
    Sys.Application.add_load(page_load);
    function page_load() {
        $("[id^='QueryRequest_']").each(function (index) {
            $(this).on("click", function (event) {
                var Url = "/Pages/BuildingLicense/LicenseDetails.aspx?REQUEST_NUMBER=" + $(this).data("requestno") + "&REQUEST_YEAR=" + $(this).data("requestyear");
                $.fancybox({
                    type: "iframe",
                    overlayShow: true,
                    autoCenter: true,
                    openEffect: "none",
                    closeEffect: "none",
                    autoScale: true,
                    scrollOutside: true,
                    autoDimensions: false,
                    scrolling: "no",
                    padding: 0,
                    margin: 20,
                    autoSize: false,
                    width: '100%',
                    height: '100%',
                    href: Url,
                    fitToView: true,
                    closeBtn: true,
                    closeClick: true,
                    beforeClose: function () { },
                    afterClose: function () { }
                });
                event.preventDefault();
            });
        });
    }

</script>


